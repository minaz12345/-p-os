# P-OS Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Optional: Other LLM Providers
OPENAI_API_KEY=
QWEN_API_KEY=your_qwen_api_key_here
ANTHROPIC_API_KEY=

# P-OS System Configuration
POS_API_PORT=8000
POS_API_HOST=0.0.0.0
POS_DB_PATH=data/noi_core.db

# Encryption (REQUIRED for data security)
P_OS_ENCRYPTION_KEY=generate_with_python_c_import_secrets_print_secrets_token_hex_32

# Neo4j Graph Database Configuration (TLS-enabled)
NEO4J_URI=bolt+ssc://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rotate_every_90_days_use_credential_rotation_py
NEO4J_DATABASE=neo4j

# PostgreSQL Operational Database Configuration
POSTGRESQL_URI=postgresql://pos_admin:PASSWORD@localhost:5432/pos_operational
POSTGRESQL_USER=pos_admin
POSTGRESQL_PASSWORD=rotate_every_90_days_use_credential_rotation_py
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_DB=pos_operational

# Logging
POS_LOG_LEVEL=INFO

# =============================================================================
# D3 Citizen Portal Configuration (P-OS v8.0)
# =============================================================================

# JWT Authentication
SESSION_SECRET=generate_with_python_c_import_secrets_print_secrets_token_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (RESTRICTED - Security Hardened)
CORS_ORIGINS=https://milejczyce.gov.pl,https://portal.milejczyce.gov.pl

# Server Configuration
PORT=8000
HOST=0.0.0.0

# Rate Limiting
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_GDPR=10
RATE_LIMIT_LOGIN=5

# Test/Demo Passwords (Optional - for development only)
DEMO_ENCRYPTION_PASSWORD=demo-password-do-not-use-in-production
TEST_ENCRYPTION_PASSWORD=test-password-rotate-before-production

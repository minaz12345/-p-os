# P-OS Runtime Configuration
# Last updated: 2026-05-04
# SECURITY: No secrets in this file - only configuration

# DeepSeek API Configuration (API keys should be in .env.secrets or vault)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Optional: Other LLM Providers
OPENAI_API_KEY=
QWEN_API_KEY=your_qwen_api_key_here
ANTHROPIC_API_KEY=

# P-OS System Configuration
POS_API_PORT=8000
POS_API_HOST=0.0.0.0
POS_DB_PATH=data/noi_core.db

# Logging
POS_LOG_LEVEL=INFO

# =============================================================================
# D3 Citizen Portal Configuration (P-OS v8.0)
# Added: 2026-05-03 — Production Deployment Phase 1
# =============================================================================

# CORS Configuration (RESTRICTED - Security Hardened)
CORS_ORIGINS=https://milejczyce.gov.pl,https://portal.milejczyce.gov.pl

# Server Configuration
PORT=8000
HOST=0.0.0.0

# Rate Limiting
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_GDPR=10
RATE_LIMIT_LOGIN=5

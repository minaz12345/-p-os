{
  "dashboard": {
    "id": null,
    "uid": "pos-friction-map-v1",
    "title": "P-OS Friction Map - Gmina Milejczyce",
    "tags": ["pos", "milejczyce", "friction", "passive-observation"],
    "timezone": "browser",
    "schemaVersion": 30,
    "version": 1,
    "refresh": "1m",
    "time": {
      "from": "now-7d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Citizen Feedback by Category & Status",
        "type": "bargauge",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "pos_citizen_feedback_by_status",
            "legendFormat": "{{category}} - {{status}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Service Requests Operational Load",
        "type": "table",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "pos_service_requests_by_type",
            "legendFormat": "{{service_type}} / {{priority}} / {{status}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Epistemic Health Score",
        "type": "gauge",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "pos_epistemic_health_score",
            "legendFormat": "Health Score"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 90}
              ]
            }
          }
        },
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Dry-Run Adoption Rate",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "pos_dry_run_adoption_rate",
            "legendFormat": "Adoption %"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 6,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Event Chain Integrity",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "pos_event_chain_integrity",
            "legendFormat": "{{chain_status}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        },
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Total Passive Observations",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "pos_total_observations",
            "legendFormat": "Observation Count"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 18,
          "y": 8
        }
      }
    ],
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": "-- Grafana --",
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    }
  },
  "overwrite": false
}

# P-OS Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Optional: Other LLM Providers
OPENAI_API_KEY=
QWEN_API_KEY=
ANTHROPIC_API_KEY=

# P-OS System Configuration
POS_API_PORT=8000
POS_API_HOST=0.0.0.0
POS_DB_PATH=data/noi_core.db

# Neo4j Graph Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# PostgreSQL Operational Database Configuration
POSTGRESQL_URI=postgresql://pos_admin:your_password@localhost:5432/pos_operational
POSTGRESQL_USER=pos_admin
POSTGRESQL_PASSWORD=your_password_here
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_DB=pos_operational

# Encryption (REQUIRED for data security)
P_OS_ENCRYPTION_KEY=generate_with_python_secrets_token_hex_32

# Logging
POS_LOG_LEVEL=INFO
